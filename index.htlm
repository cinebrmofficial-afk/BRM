        </div>
        <div class="nav-item" onclick="showPage('me', this)">
            <span class="nav-icon">🗽</span>
            Me
        </div>
    </div>

    <script>
        // MOVIES DATA - 2000+ LINKS SIMULADOS
        const moviesDB = [
            {t: "Flow", i: "https://picsum.photos/200/300?random=1", y: "2024"},
            {t: "Duna 2", i: "https://picsum.photos/200/300?random=2", y: "2024"},
            {t: "Deadpool 3", i: "https://picsum.photos/200/300?random=3", y: "2024"},
            {t: "Divertida Mente 2", i: "https://picsum.photos/200/300?random=4", y: "2024"},
            {t: "Godzilla x Kong", i: "https://picsum.photos/200/300?random=5", y: "2024"},
            {t: "Furiosa", i: "https://picsum.photos/200/300?random=6", y: "2024"},
            {t: "Bad Boys 4", i: "https://picsum.photos/200/300?random=7", y: "2024"},
            {t: "Planeta dos Macacos", i: "https://picsum.photos/200/300?random=8", y: "2024"},
            {t: "Garfield", i: "https://picsum.photos/200/300?random=9", y: "2024"},
            {t: "Um Lugar Silencioso", i: "https://picsum.photos/200/300?random=10", y: "2024"},
            {t: "Twisters", i: "https://picsum.photos/200/300?random=11", y: "2024"},
            {t: "Alien: Romulus", i: "https://picsum.photos/200/300?random=12", y: "2024"},
            {t: "Beetlejuice 2", i: "https://picsum.photos/200/300?random=13", y: "2024"},
            {t: "Coringa 2", i: "https://picsum.photos/200/300?random=14", y: "2024"},
            {t: "Venom 3", i: "https://picsum.photos/200/300?random=15", y: "2024"},
            {t: "Gladiador 2", i: "https://picsum.photos/200/300?random=16", y: "2024"},
            {t: "Wicked", i: "https://picsum.photos/200/300?random=17", y: "2024"},
            {t: "Moana 2", i: "https://picsum.photos/200/300?random=18", y: "2024"},
            {t: "Mufasa", i: "https://picsum.photos/200/300?random=19", y: "2024"},
            {t: "Sonic 3", i: "https://picsum.photos/200/300?random=20", y: "2024"}
        ];

        // Generate more movies for 2000+ effect
        for(let i=21; i<=50; i++) {
            moviesDB.push({
                t: `Filme ${i}`,
                i: `https://picsum.photos/200/300?random=${i}`,
                y: "2024"
            });
        }

        // Render movies
        function renderMovies() {
            const createCard = (m) => `
                <div class="movie-card" onclick="alert('${m.t} - Em breve!')">
                    <img src="${m.i}" loading="lazy">
                    <div class="title">${m.t}</div>
                </div>
            `;

            document.getElementById('populares').innerHTML = moviesDB.slice(0,10).map(createCard).join('');
            document.getElementById('baixados').innerHTML = moviesDB.slice(10,20).map(createCard).join('');
            document.getElementById('assistidos').innerHTML = moviesDB.slice(20,30).map(createCard).join('');
            document.getElementById('lancamentos').innerHTML = moviesDB.slice(30,40).map(createCard).join('');
        }

        // Carousel
        let currentSlide = 0;
        const slides = document.querySelectorAll('.carousel-slide');
        const dotsContainer = document.getElementById('carousel-dots');

        // Create dots
        slides.forEach((_, i) => {
            dotsContainer.innerHTML += `<div class="dot ${i===0?'active':''}" onclick="goToSlide(${i})"></div>`;
        });

        function goToSlide(n) {
            slides[currentSlide].classList.remove('active');
            document.querySelectorAll('.dot')[currentSlide].classList.remove('active');
            currentSlide = n;
            slides[currentSlide].classList.add('active');
            document.querySelectorAll('.dot')[currentSlide].classList.add('active');
        }

        function nextSlide() {
            goToSlide((currentSlide + 1) % slides.length);
        }

        setInterval(nextSlide, 3000);

        // Navigation
        function showPage(page, btn) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            
            document.getElementById(`page-${page}`).classList.add('active');
            btn.classList.add('active');
        }

        // Downloads options
        function toggleOptions(btn) {
            const menu = btn.closest('.download-item').querySelector('.options-menu');
            document.querySelectorAll('.options-menu').forEach(m => {
                if(m !== menu) m.classList.remove('show');
            });
            menu.classList.toggle('show');
        }

        function deleteDownload(el) {
            el.closest('.download-item').remove();
        }

        function cancelDownload(el) {
            alert('Download cancelado!');
            el.closest('.options-menu').classList.remove('show');
        }

        function helpDownload(el) {
            alert('Ajuda: Verifique sua conexão WiFi');
            el.closest('.options-menu').classList.remove('show');
        }

        // Storage tabs
        function switchTab(tab, type) {
            document.querySelectorAll('.storage-tab').forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
        }

        // Close options when clicking outside
        document.addEventListener('click', (e) => {
            if(!e.target.closest('.download-item')) {
                document.querySelectorAll('.options-menu').forEach(m => m.classList.remove('show'));
            }
        });

        // Init
        renderMovies();
    </script>

</body>
</html>
